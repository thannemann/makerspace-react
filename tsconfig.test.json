{
  "compilerOptions": {
    "allowJs": true,
    "declaration": false,
    "baseUrl": "src",
    "outDir": "dist",
    "paths": {
      "*": [
        "*",
        "src/*"
      ]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "lib": [
      "es2017",
      "dom",
      "es2018",
      "es2019",
      "es2020"
    ],
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "target": "es2017",
    "jsx": "react",
    "typeRoots": [
      "node_modules/@types",
      "src/app/typings"
    ],
    "types": [
      "jest",
      "node"
    ],
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
