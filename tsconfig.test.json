{
  "extends": "./tsconfig.base",
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "module": "commonjs",
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "typeRoots": [
      "node_modules/@types",
      "src/app/typings"
    ]
  }
}
